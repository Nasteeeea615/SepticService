# ============================================
# STAGING ENVIRONMENT VARIABLES
# ============================================
# 
# Это пример конфигурации для staging окружения.
# Скопируйте в .env.staging и заполните реальными значениями.
# 
# ⚠️ ВАЖНО:
# - Staging должен быть максимально близок к production
# - Используйте отдельные базы данных и Redis
# - Не используйте production секреты в staging
# - Добавьте .env.staging в .gitignore
# ============================================

# --------------------------------------------
# Environment
# --------------------------------------------
NODE_ENV=staging

# --------------------------------------------
# Database (PostgreSQL) - Staging
# --------------------------------------------
STAGING_DB_HOST=localhost
STAGING_DB_PORT=5433
STAGING_DB_NAME=septik_staging
STAGING_DB_USER=postgres
STAGING_DB_PASSWORD=Lht5XhKSLbc7WlSrQC6mntQ7FuoFRHHsXmVaGGFqPCY

# --------------------------------------------
# Redis Cache - Staging
# --------------------------------------------
STAGING_REDIS_HOST=localhost
STAGING_REDIS_PORT=6380
STAGING_REDIS_PASSWORD=h24mUYYzQ99W6aVXsw0btpVd8koztrzlQVvUwTXDRU

# --------------------------------------------
# JWT Authentication (можно использовать те же, что и в production)
# --------------------------------------------
JWT_SECRET=QonqBFQAlNEvfowCSByw5JTt45h7PKexc80EvsTHSr95H4nDj3CGcOPPMEuP5zBu6ZajFN9IGDL89sJZo1CJ+g==
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=FO2hBLtdy/tpKlbdq7fAChnwQ2o7KkpFe2ZVEGiR/Vr/lNvTCQhR56wtFHkveJ8z0SRhwMIuo5kouLlLe/0rkA==
JWT_REFRESH_EXPIRES_IN=7d

# --------------------------------------------
# Application URLs - Staging
# --------------------------------------------
STAGING_URL=http://localhost:3002
STAGING_API_URL=http://localhost:3002/api
STAGING_FRONTEND_URL=http://localhost:3000
STAGING_ADMIN_URL=http://localhost:3003

# --------------------------------------------
# Ports - Staging (отличаются от production)
# --------------------------------------------
STAGING_BACKEND_PORT=3002
STAGING_ADMIN_PORT=3003
STAGING_NGINX_HTTP_PORT=8080
STAGING_NGINX_HTTPS_PORT=8443

# --------------------------------------------
# Payment Gateway (YooKassa) - Тестовый режим
# --------------------------------------------
# ⚠️ Используйте тестовые credentials от ЮКасса
# Получить: https://yookassa.ru/developers/using-api/testing
YOOKASSA_SHOP_ID=your_test_shop_id
YOOKASSA_SECRET_KEY=your_test_secret_key
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_RETURN_URL=septikservice://payment/return

# Webhook секрет для staging (отдельный от production)
STAGING_WEBHOOK_SECRET=81306fad2133ad58625d224786760566d0ef5e002c6193c1e74ba80965730e63

# --------------------------------------------
# Firebase Cloud Messaging - Staging
# --------------------------------------------
# Можно использовать тот же проект или создать отдельный
FIREBASE_SERVICE_ACCOUNT=

# --------------------------------------------
# SMS Gateway - Staging (опционально)
# --------------------------------------------
# Используйте тестовый API ключ или отключите
SMS_API_KEY=

# --------------------------------------------
# Backup Configuration
# --------------------------------------------
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/var/backups/septik-staging

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_DIR=/app/logs

# --------------------------------------------
# Feature Flags (для тестирования новых функций)
# --------------------------------------------
FEATURE_NEW_PAYMENT_FLOW=true
FEATURE_ENHANCED_NOTIFICATIONS=true
FEATURE_BETA_UI=false

# ============================================
# ЧЕКЛИСТ ПЕРЕД ЗАПУСКОМ STAGING:
# ============================================
# [ ] Все секреты сгенерированы и отличаются от production
# [ ] База данных создана и изолирована
# [ ] Redis использует отдельный порт
# [ ] YooKassa настроена в тестовом режиме
# [ ] Webhook URL обновлен в ЮКасса
# [ ] Логирование настроено
# [ ] Бэкапы настроены
# ============================================
